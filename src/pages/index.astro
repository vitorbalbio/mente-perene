---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

// Get all blog posts and sort them by date
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Show up to 5 posts on the frontpage
const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout title="Início">
  <div class="max-w-4xl mx-auto">
  
      <section class="text-center py-[8vh]" transition:animate="fade">
      <img
                src="/images/banner.jpg"
                alt="Mente Perene"
                class="w-full h-auto rounded-lg shadow-lg"
                loading="eager"
              />
      <h1 class="text-7xl mb-8 font-bold">Mente Perene</h1>
      <p class="text-2xl text-muted-foreground max-w-3xl mx-auto mb-14">
        Artigos e pensamentos de uma mente inquieta. Esse é meu espaço pessoal para investigar as grandes
        questões sem preconceitos e onde ciência, filosofia e o sentido da existência se encontram.
      </p>
    </section>

    

    <section class="mx-auto" transition:animate="fade">
      <PostList posts={posts} showImages={false} showExcerpt={false} showSeparators={true} showTags={false}/>

      <div class="text-center mt-24">
        <a href="/blog" class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
          Ver todos os posts <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
