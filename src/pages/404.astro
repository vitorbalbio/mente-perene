---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Página não encontrada" description="A página que você procura não existe ou foi movida.">
  <div class="flex flex-col items-center justify-center text-center min-h-[80vh] py-16 md:py-24">
    <h1 class="text-6xl md:text-8xl font-bold text-gray-900 mb-4">404</h1>
    <h2 class="text-2xl md:text-3xl font-medium text-gray-700 mb-8">Página não encontrada</h2>
    <p class="text-gray-600 max-w-md mb-10">
      A página que você procura não existe ou foi movida para outro lugar.
    </p>
    <a href="/" class="text-lg font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 py-2 px-4 rounded-md inline-block text-black">
      Voltar ao início <span aria-hidden="true">→</span>
    </a>
  </div>
</BaseLayout>
